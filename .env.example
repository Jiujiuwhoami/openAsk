# === 应用基础配置 ===
APP_NAME=OpenAsk
ENVIRONMENT=development
DEBUG=false

# === LLM API 配置（兼容 OpenAI 格式） ===
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# === Zvec 向量数据库配置 ===
ZVEC_DATA_PATH=data/zvec
ZVEC_DIMENSION=384
ZVEC_CACHE_PATH=data/zvec_llm_cache
ZVEC_CACHE_DIMENSION=384

# === 嵌入服务配置 ===
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE_EMBEDDINGS=true

# === API 服务配置 ===
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_KEY=  # 为空时不启用 API Key 认证

# === 限流配置 ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_USER=60/minute
RATE_LIMIT_GLOBAL_LIMIT=1000/minute
RATE_LIMIT_STRATEGY=sliding_window
RATE_LIMIT_STORAGE_URI=memory://

# === LLM 缓存配置 ===
LLM_CACHE_ENABLED=true
LLM_CACHE_MAXSIZE=1000
LLM_CACHE_TTL=86400
LLM_CACHE_SIMILARITY_THRESHOLD=0.95
LLM_CACHE_STORAGE_URI=

# === 日志配置 ===
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# === 监控配置 ===
METRICS_ENABLED=true
METRICS_PORT=8000

# === 多模态服务配置 ===
MULTIMODAL_ENABLED=false
MULTIMODAL_PROVIDER=generic
MULTIMODAL_API_KEY=
MULTIMODAL_API_BASE=https://api.openai.com/v1
MULTIMODAL_MODEL=gpt-4o
MULTIMODAL_TIMEOUT=30
